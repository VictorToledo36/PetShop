@inherits LayoutComponentBase

<div class="page">
    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-dark fixed-top" style="background-color: #6a0dad;">
        <div class="container">
            <a class="navbar-brand fw-bold fs-4" href="/">
                🐾 Cantinho da Roça
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto align-items-center gap-2">
                    <li class="nav-item">
                        <a class="nav-link text-white" href="/">Início</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white" href="/servicos">Serviços</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white" href="/galeria">Galeria</a>
                    </li>
                    <AuthorizeView>
                        <Authorized>
                            <li class="nav-item">
                                <a class="nav-link text-white" href="/dashboard">Minha Área</a>
                            </li>
                            <li class="nav-item">
                                <form action="/Account/Logout" method="post">
                                    <AntiforgeryToken />
                                    <input type="hidden" name="returnUrl" value="/" />
                                    <button type="submit" class="btn btn-outline-light btn-sm">Sair</button>
                                </form>
                            </li>
                        </Authorized>
                        <NotAuthorized>
                            <li class="nav-item">
                                <a class="btn btn-light text-purple fw-bold btn-sm" href="/Account/Login">Login</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-warning fw-bold btn-sm" href="/Account/Register">Cadastrar</a>
                            </li>
                        </NotAuthorized>
                    </AuthorizeView>
                    <AuthorizeView Roles="Admin">
                        <li class="nav-item">
                            <a class="btn btn-danger btn-sm fw-bold" href="/admin">Admin</a>
                        </li>
                    </AuthorizeView>
                </ul>
            </div>
        </div>
    </nav>

    <!-- CONTEÚDO -->
    <main>
        @Body
    </main>

    <!-- FOOTER -->
    <footer style="background-color: #6a0dad;" class="text-white mt-5 py-4">
        <div class="container text-center">
            <p class="mb-1 fw-bold fs-5">🐾 Cantinho da Roça</p>
            <p class="mb-1 small">Pet Shop • Banho & Tosa</p>
            <p class="mb-0 small opacity-75">© 2026 Todos os direitos reservados</p>
        </div>
    </footer>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>