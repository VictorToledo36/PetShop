@inherits LayoutComponentBase
<div class="page" style="display:flex; flex-direction:column; min-height:100vh;">
    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-dark fixed-top" style="background-color: #6a0dad;">
        <div class="container">
            <a class="navbar-brand fw-bold fs-4" href="/">
                🐾 Cantinho da Roça
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto align-items-center gap-2">
                    <li class="nav-item">
                        <a class="nav-link text-white" href="/">Início</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white" href="/servicos">Serviços</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white" href="/galeria">Galeria</a>
                    </li>
                    <AuthorizeView>
                        <Authorized>
                            <li class="nav-item">
                                <a class="nav-link text-white" href="/dashboard">Minha Área</a>
                            </li>
                            <li class="nav-item">
                                <form action="/Account/Logout" method="post">
                                    <AntiforgeryToken />
                                    <input type="hidden" name="returnUrl" value="/" />
                                    <button type="submit" class="btn btn-outline-light btn-sm">Sair</button>
                                </form>
                            </li>
                        </Authorized>
                        <NotAuthorized>
                            <li class="nav-item">
                                <a class="btn btn-light text-purple fw-bold btn-sm" href="/Account/Login">Login</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-warning fw-bold btn-sm" href="/Account/Register">Cadastrar</a>
                            </li>
                        </NotAuthorized>
                    </AuthorizeView>
                    <AuthorizeView Roles="Admin">
                        <li class="nav-item">
                            <a class="btn btn-danger btn-sm fw-bold" href="/admin">Admin</a>
                        </li>
                    </AuthorizeView>
                </ul>
            </div>
        </div>
    </nav>

    <!-- CONTEÚDO -->
    <main style="flex:1;">
        @Body
    </main>

    <!-- FOOTER -->
    <footer style="background: linear-gradient(135deg, #6a0dad, #9b30ff); color: white;">
        <div class="container py-5">
            <div class="row g-4">

                <!-- SERVIÇOS -->
                <div class="col-md-4">
                    <h6 class="fw-bold mb-3" style="letter-spacing:.5px; text-transform:uppercase; font-size:13px; opacity:.7;">
                        Serviços
                    </h6>
                    <ul class="list-unstyled mb-0">
                        <li class="mb-2">
                            <a href="/servicos" style="color:rgba(255,255,255,0.85); text-decoration:none; font-size:15px;">
                                🛁 Banho
                            </a>
                        </li>
                        <li class="mb-2">
                            <a href="/servicos" style="color:rgba(255,255,255,0.85); text-decoration:none; font-size:15px;">
                                ✂️ Tosa
                            </a>
                        </li>
                        <li>
                            <a href="/servicos" style="color:rgba(255,255,255,0.85); text-decoration:none; font-size:15px;">
                                🧴 Tosa Higiênica
                            </a>
                        </li>
                    </ul>
                </div>

                <!-- CONTATOS E REDES SOCIAIS -->
                <div class="col-md-4">
                    <h6 class="fw-bold mb-3" style="letter-spacing:.5px; text-transform:uppercase; font-size:13px; opacity:.7;">
                        Contatos & Redes Sociais
                    </h6>
                    <div class="d-flex flex-column gap-3">
                        <a href="https://www.instagram.com/petcantinhodaroca/" target="_blank"
                           style="display:inline-flex; align-items:center; gap:10px;
                  color:rgba(255,255,255,0.85); text-decoration:none; font-size:15px;">
                            <div style="width:36px; height:36px; border-radius:10px;
                        background:rgba(255,255,255,0.15); display:flex;
                        align-items:center; justify-content:center;">
                                <i class="bi bi-instagram" style="font-size:18px;"></i>
                            </div>
                            &#64;petcantinhodaroca
                        </a>
                        <a href="https://wa.me/5519991443858" target="_blank"
                           style="display:inline-flex; align-items:center; gap:10px;
                  color:rgba(255,255,255,0.85); text-decoration:none; font-size:15px;">
                            <div style="width:36px; height:36px; border-radius:10px;
                        background:rgba(255,255,255,0.15); display:flex;
                        align-items:center; justify-content:center;">
                                <i class="bi bi-whatsapp" style="font-size:18px;"></i>
                            </div>
                            (19) 99144-3858
                        </a>
                    </div>
                </div>

                <!-- AGENDAMENTO -->
                <div class="col-md-4">
                    <h6 class="fw-bold mb-3" style="letter-spacing:.5px; text-transform:uppercase; font-size:13px; opacity:.7;">
                        Agende Agora
                    </h6>
                    <p style="color:rgba(255,255,255,0.75); font-size:14px; line-height:1.7; margin-bottom:16px;">
                        Seu pet merece o melhor cuidado. Agende online de forma rápida e fácil!
                    </p>
                    <a href="/agendamento" class="btn btn-warning fw-bold px-4" style="border-radius:10px;">
                        <i class="bi bi-calendar-check me-2"></i>Agendar
                    </a>
                </div>

            </div>
        </div>

        <!-- LINHA FINAL -->
        <div style="border-top:1px solid rgba(255,255,255,0.15);">
            <div class="container py-3 text-center">
                <span style="font-size:13px; opacity:.7;">
                    🐾 <strong>Cantinho da Roça</strong> • Pet Shop • Banho & Tosa •
                    © 2026 Todos os direitos reservados
                </span>
            </div>
        </div>
    </footer>

</div>  @* ← fechamento da <div class="page"> *@

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>