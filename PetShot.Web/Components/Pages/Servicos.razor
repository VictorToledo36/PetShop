@page "/servicos"
@rendermode InteractiveServer
@inject IServicoService ServicoService
@using PetShop.Application.Interfaces
@using PetShop.Domain.Entities
@using PetShop.Domain.Enums

<PageTitle>Serviços - Cantinho da Roça</PageTitle>

<!-- HERO -->
<section style="background: linear-gradient(135deg, #7c3aed, #a855f7); padding-top: 70px; position: relative;"
         class="text-white text-center py-5">
    <div class="container py-3">
        <span style="display:inline-block; background:rgba(255,255,255,0.15);
                     border:1px solid rgba(255,255,255,0.25); border-radius:20px;
                     padding:4px 14px; font-size:12px; margin-bottom:12px; letter-spacing:0.5px;">
            Pet Shop • Banho & Tosa
        </span>
        <h1 class="display-5 fw-bold mb-2">✂️ Nossos Serviços</h1>
        <p class="opacity-75">Cuidado completo para o seu pet, com preços por porte</p>
    </div>
    <div style="position:absolute; bottom:-1px; left:0; right:0; height:40px;
                background:#f7f4ff; clip-path: ellipse(55% 100% at 50% 100%);"></div>
</section>

<!-- LISTA DE SERVIÇOS -->
<section style="background:#f7f4ff; padding: 40px 0 60px;">
    <div class="container" style="max-width:820px;">

        @if (carregando)
        {
            <div class="text-center py-5">
                <div class="spinner-border" style="color: #7c3aed;" role="status"></div>
                <p class="mt-3 text-muted">Carregando serviços...</p>
            </div>
        }
        else if (!servicos.Any())
        {
            <div class="text-center py-5">
                <div class="fs-1">🐾</div>
                <h4 class="text-muted">Nenhum serviço cadastrado ainda.</h4>
                <p class="text-muted">Em breve nossos serviços estarão disponíveis!</p>
            </div>
        }
        else
        {
            @foreach (var servico in servicos)
            {
                <div style="background:white; border-radius:16px; margin-bottom:20px;
                            overflow:hidden; box-shadow:0 2px 12px rgba(124,58,237,0.08);
                            border:1px solid #ede9fe;">

                    <!-- Header do card -->
                    <div style="display:flex; align-items:center; gap:14px;
                                padding:18px 24px; border-bottom:1px solid #f3f0ff;">
                        <div style="width:44px; height:44px; background:#f3f0ff; border-radius:12px;
                                    display:flex; align-items:center; justify-content:center;
                                    font-size:20px; flex-shrink:0;">
                            @GetIconeServico(servico.Nome)
                        </div>
                        <div>
                            <div style="font-size:1.1rem; font-weight:700; color:#3b0764;">
                                @servico.Nome
                            </div>
                            @if (!string.IsNullOrEmpty(servico.Descricao))
                            {
                                <div style="font-size:13px; color:#7c3aed; margin-top:2px;">
                                    @servico.Descricao
                                </div>
                            }
                        </div>
                    </div>

                    <!-- Body do card -->
                    <div style="padding:20px 24px;">
                        @if (servico.Precos.Any())
                        {
                            <div style="font-size:11px; font-weight:600; color:#9333ea;
                                        letter-spacing:1px; text-transform:uppercase; margin-bottom:12px;">
                                Preços por porte
                            </div>
                            <div class="row g-2 mb-4">
                                @foreach (var preco in servico.Precos.OrderBy(p => p.Porte))
                                {
                                    <div class="col-6 col-md-3">
                                        <div style="background:#faf7ff; border:1px solid #ede9fe;
                                                    border-radius:12px; padding:12px 8px; text-align:center;">
                                            <div style="font-size:12px; font-weight:600; color:#7c3aed; margin-bottom:4px;">
                                                @GetIconePorte(preco.Porte) @preco.Porte.ToString()
                                            </div>
                                            <div style="font-size:1rem; font-weight:700; color:#3b0764;">
                                                <span style="font-size:11px; font-weight:400; color:#9ca3af;">R$</span>
                                                @preco.Preco.ToString("F2")
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="text-muted small mb-3">Preços sob consulta.</p>
                        }

                        <a href="/agendamento"
                           style="display:inline-flex; align-items:center; gap:8px; background:#7c3aed;
                                  color:white; border-radius:10px; padding:10px 22px; font-size:14px;
                                  font-weight:600; text-decoration:none;">
                            <i class="bi bi-calendar-check"></i> Agendar este serviço
                        </a>
                    </div>

                </div>
            }
        }

    </div>
</section>

@code {
    private List<Servico> servicos = new();
    private bool carregando = true;

    protected override async Task OnInitializedAsync()
    {
        servicos = await ServicoService.ObterTodosAsync();
        carregando = false;
    }

    private string GetIconeServico(string nome) => nome.ToLower() switch
    {
        var n when n.Contains("banho") && n.Contains("tosa") => "🛁✂️",
        var n when n.Contains("banho") => "🛁",
        var n when n.Contains("tosa higiênica") || n.Contains("higienica") => "🧴",
        var n when n.Contains("tosa") => "✂️",
        _ => "🐾"
    };

    private string GetIconePorte(PortePet porte) => porte switch
    {
        PortePet.Pequeno => "🐩",
        PortePet.Medio => "🐕",
        PortePet.Grande => "🦮",
        PortePet.GrandePorte => "🐘",
        _ => "🐾"
    };
}