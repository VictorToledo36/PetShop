@page "/admin/servicos"
@rendermode InteractiveServer
@inject IServicoService ServicoService
@inject IJSRuntime JS
@using Microsoft.AspNetCore.Authorization
@using PetShop.Application.Interfaces
@using PetShop.Domain.Entities
@using PetShop.Domain.Enums
@attribute [Authorize(Roles = "Admin")]

<PageTitle>Gerenciar Serviços - Admin</PageTitle>

<div class="container-fluid py-4" style="padding-top: 90px !important; min-height: calc(100vh - 200px);">

    <div class="container">
        <!-- HEADER -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h3 class="fw-bold mb-0" style="color: #6a0dad;">⚙️ Gerenciar Serviços</h3>
                <p class="text-muted small mb-0">Cadastre e gerencie os serviços do pet shop</p>
            </div>
            <button class="btn text-white fw-bold" style="background-color: #6a0dad;"
                    @onclick="AbrirFormNovo">
                <i class="bi bi-plus-circle me-2"></i>Novo Serviço
            </button>
        </div>
    </div>

    <div class="container">

    <!-- MENSAGEM -->
    @if (!string.IsNullOrEmpty(mensagem))
    {
        <div class="alert @(sucesso ? "alert-success" : "alert-danger") alert-dismissible">
            @mensagem
            <button type="button" class="btn-close" @onclick="() => mensagem = null"></button>
        </div>
    }

    <!-- FORMULÁRIO -->
    @if (mostrarForm)
    {
        <div class="card border-0 shadow mb-4" style="border-radius: 16px;">
            <div class="card-header text-white fw-bold py-3"
                 style="background-color: #6a0dad; border-radius: 16px 16px 0 0;">
                @(editando ? "✏️ Editar Serviço" : "➕ Novo Serviço")
            </div>
            <div class="card-body p-4">
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Nome do Serviço</label>
                        <input @bind="servicoForm.Nome" class="form-control" placeholder="Ex: Banho, Tosa..." />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Descrição</label>
                        <input @bind="servicoForm.Descricao" class="form-control" placeholder="Descrição opcional" />
                    </div>
                </div>

                <h6 class="fw-bold mb-3" style="color: #6a0dad;">💰 Preços por Porte</h6>
                <div class="row g-3">
                    @foreach (var porte in Enum.GetValues<PortePet>())
                    {
                        var porteLocal = porte;
                        <div class="col-6 col-md-3">
                            <div class="p-3 rounded" style="background-color: #f8f0ff; border: 2px solid #e0c3fc;">
                                <label class="form-label fw-bold small" style="color: #6a0dad;">
                                    @GetIconePorte(porteLocal) @porteLocal.ToString()
                                </label>
                                <div class="input-group">
                                    <span class="input-group-text">R$</span>
                                    <input type="number" step="0.01" min="0"
                                           class="form-control"
                                           value="@precosForm[porteLocal]"
                                           @onchange="e => AtualizarPreco(porteLocal, e.Value?.ToString())" />
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <div class="mt-4 d-flex gap-2">
                    <button class="btn text-white fw-bold px-4" style="background-color: #6a0dad;"
                            @onclick="SalvarServico">
                        <i class="bi bi-check-circle me-2"></i>Salvar
                    </button>
                    <button class="btn btn-outline-secondary px-4" @onclick="FecharForm">
                        Cancelar
                    </button>
                </div>
            </div>
        </div>
    }

    <!-- LISTA DE SERVIÇOS -->
    @if (carregando)
    {
        <div class="text-center py-5">
            <div class="spinner-border" style="color: #6a0dad;" role="status"></div>
        </div>
    }
    else if (!servicos.Any())
    {
        <div class="text-center py-5">
            <div class="fs-1">🐾</div>
            <h5 class="text-muted">Nenhum serviço cadastrado ainda.</h5>
        </div>
    }
    else
    {
        @foreach (var servico in servicos)
        {
            <div class="card border-0 shadow mb-3" style="border-radius: 12px; overflow: hidden;">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h5 class="fw-bold mb-1" style="color: #6a0dad;">
                                @GetIconeServico(servico.Nome) @servico.Nome
                            </h5>
                            <p class="text-muted small mb-2">@servico.Descricao</p>
                            <div class="d-flex flex-wrap gap-2">
                                @foreach (var preco in servico.Precos.OrderBy(p => p.Porte))
                                {
                                    <span class="badge rounded-pill px-3 py-2"
                                          style="background-color: #f8f0ff; color: #6a0dad; border: 1px solid #e0c3fc;">
                                        @GetIconePorte(preco.Porte) @preco.Porte — R$ @preco.Preco.ToString("F2")
                                    </span>
                                }
                            </div>
                        </div>
                        <div class="d-flex gap-2">
                            <button class="btn btn-sm btn-outline-secondary"
                                    @onclick="() => AbrirFormEditar(servico)">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-danger"
                                    @onclick="() => DesativarServico(servico.Id)">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
    </div>
</div>  @* fecha container interno *@


@code {
    private List<Servico> servicos = new();
    private bool carregando = true;
    private bool mostrarForm = false;
    private bool editando = false;
    private string? mensagem;
    private bool sucesso;

    private Servico servicoForm = new();
    private Dictionary<PortePet, decimal> precosForm = new();

    protected override async Task OnInitializedAsync()
    {
        InicializarPrecos();
        await CarregarServicos();
    }

    private void InicializarPrecos()
    {
        precosForm = Enum.GetValues<PortePet>()
            .ToDictionary(p => p, p => 0m);
    }

    private async Task CarregarServicos()
    {
        carregando = true;
        servicos = await ServicoService.ObterTodosAsync();
        carregando = false;
    }

    private void AbrirFormNovo()
    {
        servicoForm = new Servico();
        InicializarPrecos();
        editando = false;
        mostrarForm = true;
    }

    private void AbrirFormEditar(Servico servico)
    {
        servicoForm = new Servico
            {
                Id = servico.Id,
                Nome = servico.Nome,
                Descricao = servico.Descricao
            };
        InicializarPrecos();
        foreach (var preco in servico.Precos)
            precosForm[preco.Porte] = preco.Preco;

        editando = true;
        mostrarForm = true;
    }

    private void FecharForm()
    {
        mostrarForm = false;
        servicoForm = new();
        InicializarPrecos();
    }

    private async Task SalvarServico()
    {
        if (string.IsNullOrWhiteSpace(servicoForm.Nome))
        {
            mensagem = "❌ Nome do serviço é obrigatório.";
            sucesso = false;
            return;
        }

        servicoForm.Precos = precosForm
            .Where(p => p.Value > 0)
            .Select(p => new ServicoPreco
                {
                    Porte = p.Key,
                    Preco = p.Value,
                    ServicoId = servicoForm.Id
                }).ToList();

        bool resultado;
        if (editando)
            resultado = await ServicoService.AtualizarAsync(servicoForm);
        else
            resultado = await ServicoService.CriarAsync(servicoForm);

        if (resultado)
        {
            mensagem = editando ? "✅ Serviço atualizado!" : "✅ Serviço cadastrado!";
            sucesso = true;
            FecharForm();
            await CarregarServicos();
        }
        else
        {
            mensagem = "❌ Erro ao salvar serviço.";
            sucesso = false;
        }
    }

    private async Task DesativarServico(int id)
    {
        var resultado = await ServicoService.DesativarAsync(id);
        if (resultado)
        {
            mensagem = "✅ Serviço removido!";
            sucesso = true;
            await CarregarServicos();
        }
    }

    private string GetIconeServico(string nome) => nome.ToLower() switch
    {
        var n when n.Contains("banho") && n.Contains("tosa") => "🛁✂️",
        var n when n.Contains("banho") => "🛁",
        var n when n.Contains("tosa higiênica") || n.Contains("higienica") => "🧴",
        var n when n.Contains("tosa") => "✂️",
        _ => "🐾"
    };

    private string GetIconePorte(PortePet porte) => porte switch
    {
        PortePet.Pequeno => "🐩",
        PortePet.Medio => "🐕",
        PortePet.Grande => "🦮",
        PortePet.GrandePorte => "🐘",
        _ => "🐾"
    };

    private void AtualizarPreco(PortePet porte, string? valor)
    {
        if (decimal.TryParse(valor, out var resultado))
            precosForm[porte] = resultado;
    }
}