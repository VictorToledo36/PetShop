@page "/Account/ForgotPassword"
@using System.ComponentModel.DataAnnotations
@using System.Text
@using System.Text.Encodings.Web
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.WebUtilities
@using PetShop.Infrastructure.Persistence
@inject UserManager<ApplicationUser> UserManager
@inject IEmailSender<ApplicationUser> EmailSender
@inject NavigationManager NavigationManager
@inject IdentityRedirectManager RedirectManager

<PageTitle>Esqueceu sua senha?</PageTitle>

<div class="forgot-wrapper">
    <div class="forgot-card">
        <div class="forgot-header">
            <span>🐾</span>
            <h2>Cantinho da Roça</h2>
        </div>
        <p class="forgot-subtitle">Digite seu e-mail para redefinir sua senha</p>

        <EditForm Model="Input" FormName="forgot-password" OnValidSubmit="OnValidSubmitAsync" method="post">
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger" role="alert" />

            <div class="input-group-custom">
                <span class="input-icon">✉️</span>
                <InputText @bind-Value="Input.Email"
                           class="input-custom"
                           autocomplete="username"
                           placeholder="Seu e-mail" />
            </div>
            <ValidationMessage For="() => Input.Email" class="text-danger small" />

            <button type="submit" class="btn-entrar">Enviar link de redefinição</button>
        </EditForm>

        <div class="forgot-links">
            <a href="/Account/Login">← Voltar para o login</a>
        </div>
    </div>
</div>

<style>
    body {
        background: linear-gradient(135deg, #6b21a8, #7c3aed);
        min-height: 100vh;
    }

    .forgot-wrapper {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 80vh;
        padding: 2rem;
    }

    .forgot-card {
        background: white;
        border-radius: 16px;
        padding: 2.5rem 2rem;
        width: 100%;
        max-width: 420px;
        box-shadow: 0 8px 32px rgba(0,0,0,0.2);
    }

    .forgot-header {
        display: flex;
        align-items: center;
        gap: 10px;
        justify-content: center;
        margin-bottom: 0.25rem;
    }

        .forgot-header h2 {
            color: #6b21a8;
            font-weight: 700;
            margin: 0;
            font-size: 1.5rem;
        }

        .forgot-header span {
            font-size: 1.8rem;
        }

    .forgot-subtitle {
        text-align: center;
        color: #666;
        font-size: 0.9rem;
        margin-bottom: 1.5rem;
    }

    .input-group-custom {
        display: flex;
        align-items: center;
        border: 1px solid #ddd;
        border-radius: 8px;
        padding: 0.5rem 0.75rem;
        margin-bottom: 1rem;
        background: #fafafa;
    }

    .input-icon {
        margin-right: 8px;
        font-size: 1rem;
    }

    .input-custom {
        border: none;
        background: transparent;
        outline: none;
        width: 100%;
        font-size: 0.95rem;
        color: #333;
    }

    .btn-entrar {
        width: 100%;
        padding: 0.75rem;
        background: #7c3aed;
        color: white;
        border: none;
        border-radius: 8px;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        margin-top: 0.5rem;
        transition: background 0.2s;
    }

        .btn-entrar:hover {
            background: #6b21a8;
        }

    .forgot-links {
        text-align: center;
        margin-top: 1.25rem;
    }

        .forgot-links a {
            color: #7c3aed;
            text-decoration: none;
            font-size: 0.9rem;
        }

            .forgot-links a:hover {
                text-decoration: underline;
            }
</style>

@code {
    [SupplyParameterFromForm]
    private InputModel Input { get; set; } = new();

    private async Task OnValidSubmitAsync()
    {
        var user = await UserManager.FindByEmailAsync(Input.Email);
        if (user is null || !(await UserManager.IsEmailConfirmedAsync(user)))
        {
            RedirectManager.RedirectTo("Account/ForgotPasswordConfirmation");
            return;
        }

        var code = await UserManager.GeneratePasswordResetTokenAsync(user);
        code = WebEncoders.Base64UrlEncode(Encoding.UTF8.GetBytes(code));
        var callbackUrl = NavigationManager.GetUriWithQueryParameters(
            NavigationManager.ToAbsoluteUri("Account/ResetPassword").AbsoluteUri,
            new Dictionary<string, object?> { ["code"] = code });

        await EmailSender.SendPasswordResetLinkAsync(user, Input.Email, HtmlEncoder.Default.Encode(callbackUrl));
        RedirectManager.RedirectTo("Account/ForgotPasswordConfirmation");
    }

    private sealed class InputModel
    {
        [Required(ErrorMessage = "O e-mail é obrigatório")]
        [EmailAddress(ErrorMessage = "E-mail inválido")]
        public string Email { get; set; } = "";
    }
}