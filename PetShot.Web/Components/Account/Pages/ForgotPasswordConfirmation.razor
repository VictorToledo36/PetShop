@page "/Account/ForgotPasswordConfirmation"

<PageTitle>E-mail enviado!</PageTitle>

<div class="confirm-wrapper">
    <div class="confirm-card">
        <div class="confirm-icon">📬</div>
        <h2>E-mail enviado!</h2>
        <p>Verifique sua caixa de entrada e clique no link para redefinir sua senha.</p>
        <p class="confirm-tip">Não encontrou? Verifique também a pasta de <strong>spam</strong>.</p>
        <a href="/Account/Login" class="btn-voltar">← Voltar para o login</a>
    </div>
</div>

<style>
    body {
        background: linear-gradient(135deg, #6b21a8, #7c3aed);
        min-height: 100vh;
    }

    .confirm-wrapper {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 80vh;
        padding: 2rem;
    }

    .confirm-card {
        background: white;
        border-radius: 16px;
        padding: 2.5rem 2rem;
        width: 100%;
        max-width: 420px;
        text-align: center;
        box-shadow: 0 8px 32px rgba(0,0,0,0.2);
    }

    .confirm-icon {
        font-size: 3rem;
        margin-bottom: 1rem;
    }

    .confirm-card h2 {
        color: #6b21a8;
        font-weight: 700;
        margin-bottom: 0.75rem;
    }

    .confirm-card p {
        color: #555;
        font-size: 0.95rem;
        margin-bottom: 0.5rem;
    }

    .confirm-tip {
        color: #888;
        font-size: 0.85rem;
    }

    .btn-voltar {
        display: inline-block;
        margin-top: 1.5rem;
        padding: 0.65rem 1.5rem;
        background: #7c3aed;
        color: white;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 600;
        transition: background 0.2s;
    }

        .btn-voltar:hover {
            background: #6b21a8;
            color: white;
        }
</style>